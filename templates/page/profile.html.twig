{% extends 'base.html.twig' %}

{% block title %}Profile - Our Store{% endblock %}

{% block body %}
<div class="container my-5">
    <div class="row">
        <div class="col-md-3">
            <div class="card text-center p-3">
                <h5>{{ app.user.name }}</h5>
                <p class="text-muted">{{ app.user.email }}</p>
                <a href="{{ path('app_logout') }}" class="text-danger">Logout</a>
            </div>
        </div>
        <div class="col-md-9">
            <div class="card">
                <div class="card-header bg-primary text-white">Profile Information</div>
                <div class="card-body">
                    <p><strong>Name:</strong> {{ app.user.name }}</p>
                    <p><strong>Email:</strong> {{ app.user.email }}</p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}