{% extends 'base.html.twig' %}

{% block title %}Cart - Our Store{% endblock %}

{% block body %}
<div class="container my-5">
    <h1 class="mb-4">Shopping Cart</h1>
    {% if items is empty %}
        <div class="alert alert-info">Your cart is empty. <a href="{{ path('app_home') }}">Continue Shopping</a></div>
    {% else %}
    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-3">
                <div class="card-body">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Price</th>
                                <th>Quantity</th>
                                <th>Total</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in items %}
                            <tr>
                                <td>{{ item.product.name }}</td>
                                <td>${{ item.product.price }}</td>
                                <td>{{ item.quantity }}</td>
                                <td>${{ item.product.price * item.quantity }}</td>
                                <td>
                                    <a href="{{ path('cart_remove', {id: item.product.id}) }}" class="btn btn-sm btn-outline-danger">Remove</a>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
            <a href="{{ path('app_home') }}" class="btn btn-outline-primary">Continue Shopping</a>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}